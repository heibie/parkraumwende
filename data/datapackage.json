{
  "name": "parkraumwende-muenchen",
  "title": "Parkraumwende München – Offene Daten",
  "description": "Datensätze zu Parkraum, PKW-Bestand, Neuzulassungen und Mobilität in München. Zusammengestellt und veröffentlicht von Parkraumwende München.",
  "version": "1.0.0",
  "homepage": "https://data.parkraumwende.de",
  "contributors": [
    { "title": "Heiko Bielinski", "email": "heiko@bielinski.de", "role": "author", "path": "https://parkraumwende.de" }
  ],
  "licenses": [
    {
      "name": "CC-BY-4.0",
      "title": "Creative Commons Attribution 4.0 International",
      "path": "https://creativecommons.org/licenses/by/4.0/"
    }
  ],
  "keywords": ["parkraum", "münchen", "pkw", "mobilität", "opendata", "parking"],
  "spatial": "München, Bayern, Deutschland",
  "resources": [
    {
      "name": "parkraumkarte",
      "path": "parkraummap.csv",
      "title": "Parkraumkarte München",
      "description": "Dokumentierte Parkhäuser, Tiefgaragen und Außenstellplätze in München. Eigene Erfassung auf Basis öffentlicher Quellen (OpenData LHM, Anzeigen, Vor-Ort-Recherche). Koordinaten via Nominatim geocodiert.",
      "mediatype": "text/csv",
      "encoding": "UTF-8",
      "delimiter": ";",
      "licenses": [{ "name": "CC-BY-4.0", "path": "https://creativecommons.org/licenses/by/4.0/" }],
      "sources": [
        { "title": "OpenData Portal LHM – Parkhäuser und Tiefgaragen", "path": "https://opendata.muenchen.de/dataset/parkhaeuser-munchen" },
        { "title": "Eigene Erfassung / Crowdsourcing", "path": "https://data.parkraumwende.de" }
      ],
      "schema": {
        "fields": [
          { "name": "Name",             "type": "string",  "description": "Bezeichnung des Parkplatzes" },
          { "name": "ID",               "type": "integer", "description": "Interne ID" },
          { "name": "Typ",              "type": "string",  "description": "Parkhaus, Tiefgarage, Außenstellplatz, Wohnanlage" },
          { "name": "Bewirtschaftungsart", "type": "string", "description": "Art der Nutzung, z.B. öffentlich, Anwohner, Kunden" },
          { "name": "Immobilientyp",    "type": "string",  "description": "Gebäudetyp, z.B. Einzelhandel, Büro, Wohngebäude" },
          { "name": "Plätze",           "type": "integer", "description": "Gesamtzahl Stellplätze" },
          { "name": "Dauerparken",      "type": "string",  "description": "Dauerparken verfügbar (Ja/Nein)" },
          { "name": "Kurzzeitparken",   "type": "string",  "description": "Kurzzeitparken verfügbar (Ja/Nein)" },
          { "name": "Straße",           "type": "string",  "description": "Straßenname" },
          { "name": "Hausnummer",       "type": "string",  "description": "Hausnummer" },
          { "name": "PLZ",              "type": "string",  "description": "Postleitzahl" },
          { "name": "Ort",              "type": "string",  "description": "Ort (i.d.R. München)" },
          { "name": "Latitude",         "type": "number",  "description": "Geographische Breite (WGS84)" },
          { "name": "Longitude",        "type": "number",  "description": "Geographische Länge (WGS84)" },
          { "name": "Quelle",           "type": "string",  "description": "Datenherkunft des Eintrags" },
          { "name": "Aktiv",            "type": "string",  "description": "Eintrag aktiv/sichtbar (Ja/Nein)" }
        ]
      }
    },
    {
      "name": "parkhaeuser-innenstadt",
      "path": "parkhaeuser.csv",
      "title": "Parkhäuser Innenstadt München – Stammdaten",
      "description": "Stammdaten der am Parkleitsystem München Zentrum (PLS-MUC-Z) angeschlossenen Parkhäuser. Kapazitäten, Adressen und Koordinaten.",
      "mediatype": "text/csv",
      "encoding": "UTF-8",
      "sources": [
        { "title": "Parkleitsystem München Zentrum (pls-muc-z.com)", "path": "https://pls-muc-z.com/pls/info/parkhaus.html" }
      ],
      "schema": {
        "fields": [
          { "name": "sn",      "type": "integer", "description": "Sensor-Nummer (eindeutige ID im PLS)" },
          { "name": "ph",      "type": "string",  "description": "Parkhaus-Kürzel (P-Nummer im Leitsystem)" },
          { "name": "name",    "type": "string",  "description": "Bezeichnung des Parkhauses" },
          { "name": "adresse", "type": "string",  "description": "Anschrift" },
          { "name": "lat",     "type": "number",  "description": "Geographische Breite (WGS84)" },
          { "name": "lon",     "type": "number",  "description": "Geographische Länge (WGS84)" },
          { "name": "kap",     "type": "integer", "description": "Kapazität (Stellplätze gesamt)" },
          { "name": "url",     "type": "string",  "description": "Webseite des Parkhauses" }
        ]
      }
    },
    {
      "name": "pkw-bestand",
      "path": "pkw_bestand.csv",
      "title": "PKW-Bestand München 2010–2025",
      "description": "Jährlicher PKW-Bestand in München, aufgeschlüsselt nach Halterschaft (privat/gewerblich) und Antriebsart (Benzin, Diesel, Elektro, Hybrid u.a.).",
