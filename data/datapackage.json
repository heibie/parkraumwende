          { "name": "Dauerparken",      "type": "string",  "description": "Dauerparken verfügbar (Ja/Nein)" },
          { "name": "Kurzzeitparken",   "type": "string",  "description": "Kurzzeitparken verfügbar (Ja/Nein)" },
          { "name": "Straße",           "type": "string",  "description": "Straßenname" },
          { "name": "Hausnummer",       "type": "string",  "description": "Hausnummer" },
          { "name": "PLZ",              "type": "string",  "description": "Postleitzahl" },
          { "name": "Ort",              "type": "string",  "description": "Ort (i.d.R. München)" },
          { "name": "Latitude",         "type": "number",  "description": "Geographische Breite (WGS84)" },
          { "name": "Longitude",        "type": "number",  "description": "Geographische Länge (WGS84)" },
          { "name": "Quelle",           "type": "string",  "description": "Datenherkunft des Eintrags" },
          { "name": "Aktiv",            "type": "string",  "description": "Eintrag aktiv/sichtbar (Ja/Nein)" }
        ]
      }
    },
