      "path": "parkraummap.csv",
      "title": "Parkraumkarte München",
      "description": "Dokumentierte Parkhäuser, Tiefgaragen und Außenstellplätze in München. Eigene Erfassung auf Basis öffentlicher Quellen (OpenData LHM, Anzeigen, Vor-Ort-Recherche). Koordinaten via Nominatim geocodiert.",
      "mediatype": "text/csv",
      "encoding": "UTF-8",
      "delimiter": ";",
      "licenses": [{ "name": "CC-BY-4.0", "path": "https://creativecommons.org/licenses/by/4.0/" }],
      "sources": [
        { "title": "OpenData Portal LHM – Parkhäuser und Tiefgaragen", "path": "https://opendata.muenchen.de/dataset/parkhaeuser-munchen" },
